APP_NAME="Echo-Realm"
APP_ENV=local
APP_KEY=base64:GENERATE_THIS_WITH_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://localhost/echo-realm/public

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=echo_realm
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@echo-realm.com"
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_EMAIL=admin@echo-realm.com
ADMIN_PASSWORD=admin123
